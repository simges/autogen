Final SQL query: SELECT c.CountryName FROM countries AS c JOIN continents AS cont ON c.Continent = cont.ContId JOIN car_makers AS cm ON c.CountryId = cm.Country WHERE cont.Continent = 'Europe' COLLATE NOCASE GROUP BY c.CountryName HAVING COUNT(cm.Id) >= 3;
