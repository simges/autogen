Final SQL query: SELECT h1.name FROM Highschooler AS h1 JOIN Friend AS f ON h1.ID = f.student_id OR h1.ID = f.friend_id WHERE h1.grade > 5 GROUP BY h1.ID HAVING COUNT(DISTINCT CASE WHEN h1.ID = f.student_id THEN f.friend_id ELSE f.student_id END) >= 2;
