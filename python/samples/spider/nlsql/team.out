Final SQL query: SELECT TT.treatment_type_description FROM Treatments AS T JOIN Treatment_Types AS TT ON T.treatment_type_code = TT.treatment_type_code GROUP BY TT.treatment_type_code ORDER BY SUM(T.cost_of_treatment) ASC LIMIT 1;
